    "@hyperledger/cactus-plugin-keychain-memory": "2.0.0-rc.2",
    "axios": "1.7.2",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "typescript-optional": "2.0.1"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "publishConfig": {
    "access": "public"
  },
