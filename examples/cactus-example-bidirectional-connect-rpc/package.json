    "webpack:dev:web": "webpack --env=dev --target=web --config ../../webpack.config.js"
  },
  "dependencies": {
    "@hyperledger/cactus-cmd-api-server": "2.0.0-rc.2",
    "@hyperledger/cactus-common": "2.0.0-rc.2",
